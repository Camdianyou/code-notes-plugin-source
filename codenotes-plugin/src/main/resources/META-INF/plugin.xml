<idea-plugin>
    <id>com.codenotes.plugin</id>
    <name>Code Notes</name>
    <vendor>liangp_9</vendor>

    <description><![CDATA[
      <p>Attach persistent, structured knowledge notes directly to your source code —
      files, classes, methods, or any selected code — without leaving the IDE.</p>
      <ul>
        <li>Right-click any code and "Add Code Note..." (comment, bug, question, architecture, TODO, etc.)</li>
        <li>Notes survive minor edits via line + content-hash anchoring</li>
        <li>Gutter icons with hover previews on annotated lines</li>
        <li>Searchable Code Notes tool window with jump-to-code navigation</li>
        <li>Bilingual UI: English / 简体中文, follows the IDE locale automatically</li>
        <li>Notes are stored per-project in .idea/codeNotes.xml — plain text, git-friendly</li>
      </ul>
      <p>This is an actively evolving MVP. Planned next: Markdown/Mermaid rich editor,
      Kanban TODO board, knowledge graph view, and AI-assisted note generation.</p>
    ]]></description>

    <!-- Compatible with IntelliJ Platform 2023.1 (build 231) and later, any edition -->
    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <toolWindow id="Code Notes"
                    anchor="right"
                    icon="/icons/toolWindowIcon.svg"
                    factoryClass="com.codenotes.plugin.toolwindow.CodeNotesToolWindowFactory"/>

        <projectService serviceImplementation="com.codenotes.plugin.state.NoteStorageService"/>
        <projectService serviceImplementation="com.codenotes.plugin.repository.NoteRepository"/>
        <projectService serviceImplementation="com.codenotes.plugin.repository.CodeReviewRepository"/>
        <applicationService serviceImplementation="com.codenotes.plugin.settings.CodeNotesSettingsState"/>

        <applicationConfigurable
            parentId="tools"
            instance="com.codenotes.plugin.settings.CodeNotesConfigurable"
            id="com.codenotes.plugin.settings.CodeNotesConfigurable"
            displayName="Code Notes"/>

        <editorFactoryListener implementation="com.codenotes.plugin.gutter.NoteGutterEditorListener"/>

        <notificationGroup id="CodeNotes.Notifications" displayType="BALLOON"/>
    </extensions>

    <actions>
        <group id="CodeNotes.EditorPopupGroup" text="Code Notes" popup="true">
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
            <action id="CodeNotes.AddNote"
                    class="com.codenotes.plugin.actions.AddNoteAction">
                <keyboard-shortcut keymap="$default" first-keystroke="alt M"/>
            </action>
            <action id="CodeNotes.AddClipboardNote"
                    class="com.codenotes.plugin.actions.AddClipboardNoteAction">
                <keyboard-shortcut keymap="$default" first-keystroke="ctrl alt V"/>
            </action>
            <action id="CodeNotes.AddCodeReviewIssue"
                    class="com.codenotes.plugin.actions.AddCodeReviewIssueAction">
                <keyboard-shortcut keymap="$default" first-keystroke="ctrl alt R"/>
            </action>
        </group>
    </actions>
</idea-plugin>
